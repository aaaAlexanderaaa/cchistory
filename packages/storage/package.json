{
  "name": "@cchistory/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./store-layout": {
      "types": "./dist/store-layout.d.ts",
      "default": "./dist/store-layout.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @cchistory/domain build && tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/index.test.js"
  },
  "dependencies": {
    "@cchistory/domain": "workspace:*"
  }
}
