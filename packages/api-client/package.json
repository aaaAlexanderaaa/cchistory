{
  "name": "@cchistory/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@cchistory/domain": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @cchistory/domain build && tsc -p tsconfig.json",
    "test": "pnpm --filter @cchistory/api build && pnpm run build && node --import ../../scripts/install-node-sqlite-warning-filter.mjs --test dist/index.test.js"
  }
}
