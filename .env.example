# CCHistory Environment Variables
# Copy this file to .env and adjust as needed.

# ── API Server ──────────────────────────────────────────────

# Optional API authentication token. When set, all non-agent API requests
# must include this token in the Authorization header (Bearer <token>).
# Leave unset to disable API auth (suitable for localhost / trusted LAN).
# CCHISTORY_API_TOKEN=

# Data directory for the API server's SQLite store.
# Defaults to the nearest .cchistory/ ancestor or ~/.cchistory/.
# CCHISTORY_API_DATA_DIR=

# API server host and port. Defaults: HOST=127.0.0.1, PORT=8040.
# HOST=127.0.0.1
# PORT=8040

# CORS origin for cross-origin web requests. Defaults to http://localhost:8085.
# CCHISTORY_CORS_ORIGIN=http://localhost:8085

# ── Web Frontend ────────────────────────────────────────────

# API base URL for the web frontend. Defaults to http://localhost:8040.
# NEXT_PUBLIC_CCHISTORY_API_BASE_URL=http://localhost:8040

# ── Remote Agent ────────────────────────────────────────────

# Pairing token for remote agent authentication.
# Required only when using the remote agent collection feature.
# CCHISTORY_AGENT_PAIRING_TOKEN=

# ── Diagnostics ─────────────────────────────────────────────

# Show runtime warnings (e.g., node:sqlite ExperimentalWarning).
# Set to "true" to see all warnings. Default: suppressed.
# CCHISTORY_SHOW_RUNTIME_WARNINGS=false

# ── Internal (development only) ─────────────────────────────

# Internal API origin used by the web proxy route. Normally auto-detected.
# CCHISTORY_INTERNAL_API_ORIGIN=http://127.0.0.1:8040
